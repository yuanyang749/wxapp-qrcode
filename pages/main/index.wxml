<!-- pages/main/index.wxml -->
<view class="container-box">
  <view class="img-box">
    <image bindtap="previewImg" mode="scaleToFill" src="{{imagePath}}"></image>
  </view>

  <form bindsubmit="formSubmit">
    <view class="input-row">
      <label>内容</label>
      <input
        name="url"
        value="{{qrInput}}"
        type="text"
        maxlength="255"
        placeholder="{{placeholder}}"
        bindinput="onFieldInput"
        data-key="qrInput"
      />
    </view>

    <view class="input-row">
      <label>前景色</label>
      <input
        value="{{foregroundColor}}"
        type="text"
        maxlength="7"
        placeholder="#000000"
        bindinput="onFieldInput"
        data-key="foregroundColor"
      />
    </view>

    <view class="input-row">
      <label>背景色</label>
      <input
        value="{{backgroundColor}}"
        type="text"
        maxlength="7"
        placeholder="#ffffff"
        bindinput="onFieldInput"
        data-key="backgroundColor"
      />
    </view>

    <view class="switch-row">
      <label>渐变前景</label>
      <switch checked="{{gradientEnabled}}" bindchange="onFieldSwitch" data-key="gradientEnabled" />
    </view>

    <view wx:if="{{gradientEnabled}}">
      <view class="input-row">
        <label>渐变起始</label>
        <input
          value="{{gradientStartColor}}"
          type="text"
          maxlength="7"
          placeholder="#000000"
          bindinput="onFieldInput"
          data-key="gradientStartColor"
        />
      </view>
      <view class="input-row">
        <label>渐变结束</label>
        <input
          value="{{gradientEndColor}}"
          type="text"
          maxlength="7"
          placeholder="#409eff"
          bindinput="onFieldInput"
          data-key="gradientEndColor"
        />
      </view>
      <view class="input-row">
        <label>渐变角度</label>
        <input
          value="{{gradientAngle}}"
          type="number"
          placeholder="45"
          bindinput="onFieldInput"
          data-key="gradientAngle"
        />
      </view>
    </view>

    <view class="switch-row">
      <label>启用 Logo</label>
      <switch checked="{{logoEnabled}}" bindchange="onFieldSwitch" data-key="logoEnabled" />
    </view>

    <view wx:if="{{logoEnabled}}">
      <radio-group class="logo-source-group" bindchange="onLogoSourceChange">
        <label class="radio-item">
          <radio value="local" checked="{{logoSourceType==='local'}}" />
          <text>本地图片</text>
        </label>
        <label class="radio-item">
          <radio value="url" checked="{{logoSourceType==='url'}}" />
          <text>网络 URL</text>
        </label>
      </radio-group>

      <view wx:if="{{logoSourceType==='local'}}" class="logo-local-row">
        <button type="default" size="mini" bindtap="chooseLogoImage">选择 Logo</button>
        <text class="logo-path">{{logoLocalPath ? '已选择本地图片' : '未选择图片'}}</text>
      </view>

      <view wx:if="{{logoSourceType==='url'}}" class="input-row">
        <label>Logo URL</label>
        <input
          value="{{logoUrl}}"
          type="text"
          placeholder="https://example.com/logo.png"
          bindinput="onFieldInput"
          data-key="logoUrl"
        />
      </view>

      <view class="input-row">
        <label>Logo比例</label>
        <input value="{{logoSizeRatio}}" type="digit" placeholder="0.2" bindinput="onFieldInput" data-key="logoSizeRatio" />
      </view>
      <view class="input-row">
        <label>Logo留白</label>
        <input value="{{logoPadding}}" type="number" placeholder="4" bindinput="onFieldInput" data-key="logoPadding" />
      </view>
      <view class="input-row">
        <label>圆角半径</label>
        <input
          value="{{logoBorderRadius}}"
          type="number"
          placeholder="8"
          bindinput="onFieldInput"
          data-key="logoBorderRadius"
        />
      </view>
      <view class="input-row">
        <label>遮罩底色</label>
        <input
          value="{{logoBackgroundColor}}"
          type="text"
          maxlength="7"
          placeholder="#ffffff"
          bindinput="onFieldInput"
          data-key="logoBackgroundColor"
        />
      </view>
    </view>

    <view wx:if="{{renderWarnings.length}}" class="warning-box">
      <view class="warning-title">渲染提示：</view>
      <view wx:for="{{renderWarnings}}" wx:key="*this" class="warning-item">- {{item}}</view>
    </view>

    <button formType="submit" class="mybtn" type="primary">生成二维码</button>
  </form>
</view>

<view hidden="{{maskHidden}}" class="mask"></view>
<view class="canvas-box">
  <canvas style="width: 686rpx;height: 686rpx;background:#f1f1f1;" canvas-id="mycanvas" />
</view>
